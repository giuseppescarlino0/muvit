---
const services = [
  {
    number: "01",
    title: "Prenotazione veloce",
    text: "Un flusso semplice e immediato per scegliere il veicolo giusto e confermare in pochi passaggi.",
  },
  {
    number: "02",
    title: "Esperienza intuitiva",
    text: "Interfaccia chiara, leggibile e mobile-first, pensata per accompagnare l’utente senza distrazioni.",
  },
  {
    number: "03",
    title: "Supporto affidabile",
    text: "Informazioni trasparenti, assistenza costante e un sistema costruito per generare fiducia fin dal primo click.",
  },
];
---

<section class="services" id="services">
  <div class="container">
    <div class="section-head">
      <p class="section-kicker">Servizi</p>
      <h2>Un’esperienza progettata per convertire, con chiarezza e velocità.</h2>
      <p class="section-text">
        Ogni sezione accompagna l’utente in modo naturale: scoperta, confronto
        e prenotazione. Tutto con una UI essenziale e riconoscibile.
      </p>
    </div>

    <div class="services-grid">
      {services.map((service) => (
        <article class="service-card">
          <span class="service-number">{service.number}</span>
          <h3>{service.title}</h3>
          <p>{service.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .services {
    padding: 88px 0;
    background: linear-gradient(180deg, #f4ede7 0%, #f8f3ee 100%);
  }

  .container {
    width: min(1200px, calc(100% - 32px));
    margin: 0 auto;
  }

  .section-head {
    max-width: 760px;
    margin-bottom: 36px;
  }

  .section-kicker {
    margin: 0 0 14px;
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #e95519;
  }

  .section-head h2 {
    margin: 0;
    font-size: clamp(2.2rem, 4vw, 4rem);
    line-height: 0.98;
    letter-spacing: -0.05em;
    color: #1a1a1a;
  }

  .section-text {
    margin: 18px 0 0;
    max-width: 58ch;
    font-size: 1.04rem;
    line-height: 1.75;
    color: #5f5a56;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
  }

  .service-card {
    padding: 30px;
    border-radius: 28px;
    background: rgba(255, 255, 255, 0.78);
    border: 1px solid rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(12px);
    box-shadow: 0 18px 42px rgba(31, 20, 14, 0.08);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .service-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 24px 52px rgba(31, 20, 14, 0.12);
  }

  .service-number {
    display: inline-flex;
    margin-bottom: 18px;
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #e95519;
  }

  .service-card h3 {
    margin: 0 0 12px;
    font-size: 1.45rem;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: #1a1a1a;
  }

  .service-card p {
    margin: 0;
    font-size: 0.98rem;
    line-height: 1.75;
    color: #5f5a56;
  }

  @media (max-width: 1024px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .services {
      padding: 64px 0;
    }

    .service-card {
      padding: 24px;
      border-radius: 22px;
    }

    .section-head {
      margin-bottom: 28px;
    }
  }
</style>