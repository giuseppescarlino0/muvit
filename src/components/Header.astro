---
const navItems = [
  { label: "Servizi", href: "/services" },
  { label: "Flotta", href: "/fleet" },
  { label: "Contatti", href: "/contatti" },
];
---

<header class="site-header">
  <div class="container header-wrap">
    <a href="/" class="brand" aria-label="MUVIT home">
      <img src="/images/logo/logo-brand.png" alt="MUVIT" class="brand-logo" />
    </a>

    <nav class="desktop-nav" aria-label="Navigazione principale">
      {navItems.map((item) => (
        <a href={item.href} class="nav-link">{item.label}</a>
      ))}
      <a href="#booking" class="cta-button">Prenota Ora</a>
    </nav>

    <button class="mobile-toggle" aria-label="Apri menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    width: 100%;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  }

  .container {
    width: min(1200px, calc(100% - 32px));
    margin: 0 auto;
  }

  .header-wrap {
    min-height: 84px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
  }

  .brand-logo {
    height: 80px;
    width: auto;
    display: block;
  }

  .desktop-nav {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 28px;
    margin-left: auto;
  }

  .nav-link {
    font-size: 0.98rem;
    font-weight: 500;
    color: #1f1f1f;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .nav-link:hover {
    opacity: 0.7;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 22px;
    border-radius: 999px;
    background: #e95519;
    color: #fff;
    font-weight: 700;
    text-decoration: none;
    transition: transform 0.2s ease, background 0.2s ease;
  }

  .cta-button:hover {
    background: #cf4912;
    transform: translateY(-1px);
  }

  .mobile-toggle {
    display: none;
    width: 46px;
    height: 46px;
    padding: 0;
    border: 0;
    background: transparent;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
  }

  .mobile-toggle span {
    width: 22px;
    height: 2px;
    background: #1f1f1f;
    display: block;
    border-radius: 99px;
  }

  @media (max-width: 900px) {
    .desktop-nav {
      display: none;
    }

    .mobile-toggle {
      display: inline-flex;
    }

    .header-wrap {
      min-height: 76px;
    }

    .brand-logo {
      height: 36px;
    }
  }
</style>