---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
---

<BaseLayout canonicalPath="/cookie-policy">
  <Header />

  <main class="legal-page">
    <div class="container">
      <h1>Cookie Policy</h1>

      <p>
        Questo sito utilizza cookie tecnici necessari al funzionamento.
      </p>

      <p>
        Eventuali cookie di terze parti saranno utilizzati solo previo consenso.
      </p>

    </div>
  </main>
</BaseLayout>