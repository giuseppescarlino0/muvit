---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import FinalCta from "../../components/FinalCta.astro";
import {
  rentalRates,
  rentalVehicleClasses,
  sharingRates,
  sharingVehicleClasses,
} from "../../config/fleetPricing";

const pricingData = {
  rentalRates,
  rentalVehicleClasses,
  sharingRates,
  sharingVehicleClasses,
};

const serviceCards = [
  {
    id: "sharing",
    title: "Sharing",
    badge: "A ore + km",
    description:
      "Il cliente sceglie fascia oraria, numero di ore e chilometri previsti. Il sistema calcola subito il totale.",
    highlights: ["Compact E", "Medium", "Comfort E"],
  },
  {
    id: "rental",
    title: "Rental",
    badge: "A giorni",
    description:
      "Il cliente sceglie categoria, stagione, soglia km giornaliera e durata. Gli sconti si applicano in automatico.",
    highlights: ["Compact", "Medium", "Comfort", "Premium", "Van"],
  },
];

const mileageOptionLabels = {
  "80": "< 80 km al giorno",
  "200": "< 200 km al giorno",
  unlimited: "Km illimitati",
};
---

<BaseLayout canonicalPath="/flotta" title="Flotta e Tariffe | MUVIT">
  <Header />

  <main class="fleet-page">
    <section class="fleet-hero">
      <div class="container">
        <p class="fleet-kicker">Flotta e tariffe</p>
        <h1>Preventivo immediato per Sharing e Rental.</h1>
        <p class="fleet-intro">
          Abbiamo tenuto solo i servizi che ti servono davvero: <strong>Sharing</strong> e
          <strong>Rental</strong>. Qui il cliente può capire subito quanto spenderà, mentre voi
          potete aggiornare i prezzi in un solo file.
        </p>
      </div>
    </section>

    <section class="fleet-section">
      <div class="container fleet-layout">
        <aside class="fleet-filters">
          <div class="filter-card">
            <p class="filter-kicker">Preventivo</p>
            <h2>Configura la tariffa</h2>
            <p class="filter-copy">
              Scegli il servizio e compila i campi. Il totale viene aggiornato in tempo reale.
            </p>

            <div class="filter-group">
              <label for="serviceType">Servizio</label>
              <select id="serviceType" class="filter-input">
                <option value="all">Mostra tutto</option>
                <option value="sharing">Sharing</option>
                <option value="rental">Rental</option>
              </select>
            </div>

            <div id="sharingFilters" class="calculator-block">
              <div class="filter-group">
                <label for="sharingClass">Categoria sharing</label>
                <select id="sharingClass" class="filter-input">
                  {sharingVehicleClasses.map((vehicleClass) => (
                    <option value={vehicleClass.id}>{vehicleClass.label}</option>
                  ))}
                </select>
              </div>

              <div class="filter-group">
                <label for="sharingRateType">Tariffa oraria</label>
                <select id="sharingRateType" class="filter-input">
                  <option value="hourly">Base all'ora</option>
                  <option value="weekend">Weekend</option>
                  <option value="night">Notturno</option>
                </select>
              </div>

              <div class="filter-group">
                <label for="sharingHours">Ore previste</label>
                <input id="sharingHours" class="filter-input" type="number" min="1" value="4" />
              </div>

              <div class="filter-group">
                <label for="sharingKm">Km previsti</label>
                <input id="sharingKm" class="filter-input" type="number" min="1" value="70" />
              </div>
            </div>

            <div id="rentalFilters" class="calculator-block" hidden>
              <div class="filter-group">
                <label for="rentalClass">Categoria rental</label>
                <select id="rentalClass" class="filter-input">
                  {rentalVehicleClasses.map((vehicleClass) => (
                    <option value={vehicleClass.id}>{vehicleClass.label}</option>
                  ))}
                </select>
              </div>

              <div class="filter-group">
                <label for="rentalSeason">Periodo</label>
                <select id="rentalSeason" class="filter-input">
                  {rentalRates.seasons.map((season) => (
                    <option value={season.id}>{season.label}</option>
                  ))}
                </select>
              </div>

              <div class="filter-group">
                <label for="rentalMileage">Pacchetto km</label>
                <select id="rentalMileage" class="filter-input">
                  {rentalRates.mileageOptions.map((option) => (
                    <option value={option.id}>{mileageOptionLabels[option.id]}</option>
                  ))}
                </select>
              </div>

              <div class="filter-group">
                <label for="rentalDays">Giorni</label>
                <input id="rentalDays" class="filter-input" type="number" min="1" value="5" />
              </div>
            </div>

            <button id="resetFilters" type="button" class="filter-reset">
              Reset configurazione
            </button>

            <div class="quote-box" id="quoteBox">
              <p class="quote-kicker">Totale stimato</p>
              <strong class="quote-total" id="quoteTotal">€0,00</strong>
              <p class="quote-note" id="quoteNote">
                Compila i filtri per visualizzare subito il preventivo.
              </p>
            </div>
          </div>
        </aside>

        <div class="fleet-results">
          <div class="results-head">
            <p class="results-count">
              <span id="resultsCount">{serviceCards.length}</span> soluzioni disponibili
            </p>
          </div>

          <div class="service-grid" id="fleetGrid">
            {serviceCards.map((card) => (
              <article class="service-card" data-service={card.id}>
                <div class="service-card-top">
                  <div>
                    <p class="service-label">Servizio</p>
                    <h3>{card.title}</h3>
                  </div>
                  <span class="service-badge">{card.badge}</span>
                </div>

                <p class="service-description">{card.description}</p>

                <ul class="service-highlights">
                  {card.highlights.map((highlight) => (
                    <li>{highlight}</li>
                  ))}
                </ul>
              </article>
            ))}
          </div>

          <p class="no-results" id="noResults" hidden>
            Nessun servizio trovato con i filtri selezionati.
          </p>

          <section class="pricing-panel" data-service-panel="sharing">
            <div class="panel-head">
              <div>
                <p class="panel-kicker">Tabella sharing</p>
                <h2>Tariffe orarie e costo km</h2>
              </div>
              <p class="panel-copy">
                La tariffa totale somma <strong>costo orario</strong> e <strong>costo km</strong>
                in base allo scaglione di percorrenza stimato.
              </p>
            </div>

            <div class="table-wrap">
              <table class="pricing-table">
                <thead>
                  <tr>
                    <th>Categoria</th>
                    <th>Base all'ora</th>
                    <th>Weekend</th>
                    <th>Notturno</th>
                    <th>&lt; 100 km</th>
                    <th>100 - 199 km</th>
                    <th>200+ km</th>
                    <th>Note</th>
                  </tr>
                </thead>
                <tbody>
                  {sharingVehicleClasses.map((vehicleClass) => {
                    const rates = sharingRates.classes[vehicleClass.id];

                    return (
                      <tr>
                        <th>{vehicleClass.label}</th>
                        <td>{rates.hourly.toLocaleString("it-IT", { style: "currency", currency: "EUR" })}</td>
                        <td>{rates.weekend.toLocaleString("it-IT", { style: "currency", currency: "EUR" })}</td>
                        <td>{rates.night.toLocaleString("it-IT", { style: "currency", currency: "EUR" })}</td>
                        <td>{rates.kmUnder100.toLocaleString("it-IT", { style: "currency", currency: "EUR" })}</td>
                        <td>{rates.km100To199.toLocaleString("it-IT", { style: "currency", currency: "EUR" })}</td>
                        <td>{rates.km200Plus.toLocaleString("it-IT", { style: "currency", currency: "EUR" })}</td>
                        <td>{vehicleClass.energyNote}</td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            </div>
          </section>

          <section class="pricing-panel" data-service-panel="rental">
            <div class="panel-head">
              <div>
                <p class="panel-kicker">Tabella rental</p>
                <h2>Tariffe giornaliere, stagionalità e sconti</h2>
              </div>
              <p class="panel-copy">
                La base è il prezzo giornaliero fino a 80 km. Il sistema aggiunge supplementi
                stagionali, maggiorazione km e sconto durata.
              </p>
            </div>

            <div class="table-wrap">
              <table class="pricing-table">
                <thead>
                  <tr>
                    <th>Categoria</th>
                    <th>Inverno</th>
                    <th>Autunno / Primavera</th>
                    <th>Estate</th>
                    <th>Alta stagione</th>
                    <th>200 km/giorno</th>
                    <th>Km illimitati</th>
                  </tr>
                </thead>
                <tbody>
                  {rentalVehicleClasses.map((vehicleClass) => {
                    const rates = rentalRates.classes[vehicleClass.id];

                    return (
                      <tr>
                        <th>{vehicleClass.label}</th>
                        <td>{rates.baseDaily.toLocaleString("it-IT", { style: "currency", currency: "EUR" })}</td>
                        <td>{rates.seasonalSupplements["spring-autumn"].toLocaleString("it-IT", { style: "currency", currency: "EUR" })}</td>
                        <td>{rates.seasonalSupplements.summer.toLocaleString("it-IT", { style: "currency", currency: "EUR" })}</td>
                        <td>{rates.seasonalSupplements["high-summer"].toLocaleString("it-IT", { style: "currency", currency: "EUR" })}</td>
                        <td>+15%</td>
                        <td>+23%</td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            </div>

            <div class="table-grid">
              <div class="mini-table-card">
                <h3>Scontistiche</h3>
                <table class="mini-table">
                  <thead>
                    <tr>
                      <th>Durata</th>
                      <th>Coefficiente</th>
                    </tr>
                  </thead>
                  <tbody>
                    {rentalRates.durationDiscounts.map((discount) => (
                      <tr>
                        <th>{discount.label}</th>
                        <td>{discount.multiplier.toFixed(2)}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>

              <div class="mini-table-card">
                <h3>Divisione rental</h3>
                <table class="mini-table">
                  <thead>
                    <tr>
                      {rentalVehicleClasses.map((vehicleClass) => (
                        <th>{vehicleClass.label}</th>
                      ))}
                    </tr>
                  </thead>
                  <tbody>
                    <tr>
                      {rentalVehicleClasses.map((vehicleClass) => (
                        <td>{vehicleClass.models[0] ?? "-"}</td>
                      ))}
                    </tr>
                    <tr>
                      {rentalVehicleClasses.map((vehicleClass) => (
                        <td>{vehicleClass.models[1] ?? "-"}</td>
                      ))}
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </section>
        </div>
      </div>
    </section>

    <section class="config-note">
      <div class="container config-card">
        <p class="config-kicker">Gestione prezzi</p>
        <h2>Per aggiornare tariffe e supplementi vi basta toccare un solo file.</h2>
        <p>
          Tutti i valori del calcolatore stanno in
          <code>src/config/fleetPricing.ts</code>. Quando cambiano i prezzi, modificate lì i numeri
          senza dover toccare HTML, layout o logica del preventivo.
        </p>
      </div>
    </section>

    <FinalCta />
  </main>

  <script id="fleet-pricing-data" type="application/json" set:html={JSON.stringify(pricingData)}></script>
</BaseLayout>

<script>
  const pricingDataElement = document.querySelector("#fleet-pricing-data");
  const pricingData = pricingDataElement ? JSON.parse(pricingDataElement.textContent || "{}") : {};
  const currencyFormatter = new Intl.NumberFormat("it-IT", {
    style: "currency",
    currency: "EUR",
  });

  const serviceTypeSelect = document.querySelector("#serviceType");
  const resetButton = document.querySelector("#resetFilters");
  const serviceCards = Array.from(document.querySelectorAll(".service-card"));
  const servicePanels = Array.from(document.querySelectorAll("[data-service-panel]"));
  const resultsCount = document.querySelector("#resultsCount");
  const noResults = document.querySelector("#noResults");

  const sharingFilters = document.querySelector("#sharingFilters");
  const rentalFilters = document.querySelector("#rentalFilters");
  const quoteTotal = document.querySelector("#quoteTotal");
  const quoteNote = document.querySelector("#quoteNote");

  const sharingClassSelect = document.querySelector("#sharingClass");
  const sharingRateTypeSelect = document.querySelector("#sharingRateType");
  const sharingHoursInput = document.querySelector("#sharingHours");
  const sharingKmInput = document.querySelector("#sharingKm");

  const rentalClassSelect = document.querySelector("#rentalClass");
  const rentalSeasonSelect = document.querySelector("#rentalSeason");
  const rentalMileageSelect = document.querySelector("#rentalMileage");
  const rentalDaysInput = document.querySelector("#rentalDays");

  function clampNumber(value, fallback) {
    const parsed = Number(value);
    return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;
  }

  function getSharingKmRate(classRates, km) {
    if (km < 100) return classRates.kmUnder100;
    if (km < 200) return classRates.km100To199;
    return classRates.km200Plus;
  }

  function getSharingQuote() {
    const vehicleClass = sharingClassSelect?.value || "compact-e";
    const rateType = sharingRateTypeSelect?.value || "hourly";
    const hours = clampNumber(sharingHoursInput?.value, 1);
    const km = clampNumber(sharingKmInput?.value, 1);
    const classRates = pricingData?.sharingRates?.classes?.[vehicleClass];
    const vehicle = pricingData?.sharingVehicleClasses?.find((item) => item.id === vehicleClass);

    if (!classRates) return null;

    const hourlyRate = classRates[rateType];
    const kmRate = getSharingKmRate(classRates, km);
    const total = hourlyRate * hours + kmRate * km;
    const kmBand = km < 100 ? "< 100 km" : km < 200 ? "100 - 199 km" : "200+ km";

    return {
      total,
      note: `${vehicle?.label ?? "Sharing"}: ${currencyFormatter.format(hourlyRate)}/h, ${currencyFormatter.format(kmRate)}/km (${kmBand}). ${vehicle?.energyNote ?? ""}`.trim(),
    };
  }

  function getRentalDiscount(days) {
    return (
      pricingData?.rentalRates?.durationDiscounts?.find((discount) => {
        const matchesMin = days >= discount.minDays;
        const matchesMax = discount.maxDays === null || days <= discount.maxDays;
        return matchesMin && matchesMax;
      }) || pricingData?.rentalRates?.durationDiscounts?.[0]
    );
  }

  function getRentalQuote() {
    const vehicleClass = rentalClassSelect?.value || "compact";
    const season = rentalSeasonSelect?.value || "winter";
    const mileageOption = rentalMileageSelect?.value || "80";
    const days = clampNumber(rentalDaysInput?.value, 1);

    const classRates = pricingData?.rentalRates?.classes?.[vehicleClass];
    const mileage = pricingData?.rentalRates?.mileageOptions?.find((item) => item.id === mileageOption);
    const seasonInfo = pricingData?.rentalRates?.seasons?.find((item) => item.id === season);
    const vehicle = pricingData?.rentalVehicleClasses?.find((item) => item.id === vehicleClass);
    const discount = getRentalDiscount(days);

    if (!classRates || !mileage || !seasonInfo || !discount) return null;

    const seasonalSupplement = classRates.seasonalSupplements?.[season] ?? 0;
    const dailyBase = classRates.baseDaily + seasonalSupplement;
    const discountedDaily = dailyBase * mileage.multiplier * discount.multiplier;
    const total = discountedDaily * days;

    return {
      total,
      note: `${vehicle?.label ?? "Rental"}: ${currencyFormatter.format(dailyBase)}/giorno, ${mileage.label.toLowerCase()}, sconto ${discount.label.toLowerCase()} (${discount.multiplier.toFixed(2)}).`,
    };
  }

  function updateQuote() {
    const selectedService = serviceTypeSelect?.value || "all";
    const activeService = selectedService === "all" ? "sharing" : selectedService;
    const quote = activeService === "rental" ? getRentalQuote() : getSharingQuote();

    if (!quoteTotal || !quoteNote || !quote) return;

    quoteTotal.textContent = currencyFormatter.format(quote.total);
    quoteNote.textContent = quote.note;
  }

  function updateVisibility() {
    const selectedService = serviceTypeSelect?.value || "all";
    let visibleCount = 0;

    serviceCards.forEach((card) => {
      const isVisible =
        selectedService === "all" || card.getAttribute("data-service") === selectedService;

      card.hidden = !isVisible;
      if (isVisible) visibleCount += 1;
    });

    servicePanels.forEach((panel) => {
      const matches =
        selectedService === "all" || panel.getAttribute("data-service-panel") === selectedService;
      panel.hidden = !matches;
    });

    if (sharingFilters) sharingFilters.hidden = selectedService === "rental";
    if (rentalFilters) rentalFilters.hidden = selectedService !== "rental";
    if (resultsCount) resultsCount.textContent = String(visibleCount);
    if (noResults) noResults.hidden = visibleCount !== 0;

    updateQuote();
  }

  function resetConfiguration() {
    if (serviceTypeSelect) serviceTypeSelect.value = "all";

    if (sharingClassSelect) sharingClassSelect.value = "compact-e";
    if (sharingRateTypeSelect) sharingRateTypeSelect.value = "hourly";
    if (sharingHoursInput) sharingHoursInput.value = "4";
    if (sharingKmInput) sharingKmInput.value = "70";

    if (rentalClassSelect) rentalClassSelect.value = "compact";
    if (rentalSeasonSelect) rentalSeasonSelect.value = "winter";
    if (rentalMileageSelect) rentalMileageSelect.value = "80";
    if (rentalDaysInput) rentalDaysInput.value = "5";

    updateVisibility();
  }

  serviceTypeSelect?.addEventListener("change", updateVisibility);
  resetButton?.addEventListener("click", resetConfiguration);

  [
    sharingClassSelect,
    sharingRateTypeSelect,
    sharingHoursInput,
    sharingKmInput,
    rentalClassSelect,
    rentalSeasonSelect,
    rentalMileageSelect,
    rentalDaysInput,
  ].forEach((input) => input?.addEventListener("input", updateQuote));

  [
    sharingClassSelect,
    sharingRateTypeSelect,
    rentalClassSelect,
    rentalSeasonSelect,
    rentalMileageSelect,
  ].forEach((input) => input?.addEventListener("change", updateQuote));

  updateVisibility();
</script>

<style>
  .fleet-page {
    background:
      radial-gradient(circle at top left, rgba(233, 85, 25, 0.12), transparent 28%),
      linear-gradient(180deg, #fcf8f4 0%, #efe5dc 100%);
  }

  .container {
    width: min(1200px, calc(100% - 32px));
    margin: 0 auto;
  }

  .fleet-hero {
    padding: 72px 0 32px;
  }

  .fleet-kicker,
  .filter-kicker,
  .panel-kicker,
  .config-kicker,
  .quote-kicker,
  .service-label {
    margin: 0 0 14px;
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #e95519;
  }

  .fleet-hero h1,
  .filter-card h2,
  .panel-head h2,
  .config-card h2 {
    margin: 0;
    letter-spacing: -0.05em;
    color: #1a1a1a;
  }

  .fleet-hero h1 {
    max-width: 11ch;
    font-size: clamp(3rem, 6vw, 5.4rem);
    line-height: 0.95;
  }

  .fleet-intro,
  .filter-copy,
  .panel-copy,
  .config-card p,
  .service-description,
  .quote-note {
    margin: 18px 0 0;
    font-size: 1rem;
    line-height: 1.7;
    color: #5f5a56;
  }

  .fleet-intro {
    max-width: 64ch;
    font-size: 1.04rem;
  }

  .fleet-section {
    padding: 24px 0 88px;
  }

  .fleet-layout {
    display: grid;
    grid-template-columns: 340px minmax(0, 1fr);
    gap: 24px;
    align-items: start;
  }

  .fleet-filters {
    position: sticky;
    top: 110px;
  }

  .filter-card,
  .service-card,
  .pricing-panel,
  .config-card {
    border-radius: 30px;
    background: rgba(255, 255, 255, 0.86);
    border: 1px solid rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(16px);
    box-shadow: 0 24px 60px rgba(31, 20, 14, 0.1);
  }

  .filter-card {
    padding: 32px;
  }

  .filter-card h2 {
    font-size: clamp(1.8rem, 2.8vw, 2.4rem);
    line-height: 0.98;
  }

  .filter-group {
    display: grid;
    gap: 8px;
    margin-top: 18px;
  }

  .filter-group label {
    font-size: 0.92rem;
    font-weight: 700;
    color: #1a1a1a;
  }

  .filter-input {
    width: 100%;
    min-height: 56px;
    padding: 0 16px;
    border-radius: 18px;
    border: 1px solid rgba(0, 0, 0, 0.08);
    background: rgba(255, 255, 255, 0.96);
    font: inherit;
    color: #1a1a1a;
    outline: none;
    appearance: none;
  }

  .filter-input:focus {
    border-color: rgba(233, 85, 25, 0.45);
    box-shadow: 0 0 0 4px rgba(233, 85, 25, 0.08);
  }

  .calculator-block {
    padding-top: 6px;
  }

  .filter-reset {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 24px;
    min-height: 52px;
    width: 100%;
    padding: 0 22px;
    border-radius: 999px;
    border: none;
    background: #e95519;
    color: #fff;
    font-weight: 700;
    font-size: 0.95rem;
    cursor: pointer;
    transition: transform 160ms ease, background 160ms ease;
    box-shadow: 0 12px 30px rgba(233, 85, 25, 0.24);
  }

  .filter-reset:hover {
    transform: translateY(-1px);
    background: #cf4912;
  }

  .quote-box {
    margin-top: 22px;
    padding: 22px;
    border-radius: 24px;
    background: #161311;
    color: #fff;
  }

  .quote-kicker {
    color: rgba(255, 255, 255, 0.64);
  }

  .quote-total {
    display: block;
    font-size: clamp(2.2rem, 4vw, 3.2rem);
    line-height: 1;
    letter-spacing: -0.05em;
  }

  .quote-note {
    color: rgba(255, 255, 255, 0.72);
  }

  .results-head {
    margin-bottom: 18px;
  }

  .results-count {
    margin: 0;
    font-size: 0.95rem;
    color: #5f5a56;
  }

  .service-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
  }

  .service-card {
    padding: 28px;
  }

  .service-card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 20px;
  }

  .service-card h3 {
    margin: 0;
    font-size: 1.8rem;
    letter-spacing: -0.04em;
    color: #1a1a1a;
  }

  .service-badge {
    display: inline-flex;
    align-items: center;
    min-height: 34px;
    padding: 0 14px;
    border-radius: 999px;
    background: rgba(233, 85, 25, 0.12);
    color: #b84817;
    font-size: 0.84rem;
    font-weight: 700;
    white-space: nowrap;
  }

  .service-highlights {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    padding: 0;
    margin: 22px 0 0;
    list-style: none;
  }

  .service-highlights li {
    min-height: 34px;
    padding: 0 14px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    background: rgba(233, 85, 25, 0.08);
    color: #b84817;
    font-size: 0.84rem;
    font-weight: 700;
  }

  .pricing-panel {
    margin-top: 24px;
    padding: 28px;
  }

  .panel-head {
